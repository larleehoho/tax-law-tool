  // ==================== 三、个人所得税 ====================
  {
    "id": "individual-tax-law",
    "category": "个人所得税",
    "subCategory": "法律",
    "region": "全国",
    "title": "中华人民共和国个人所得税法",
    "docNo": "主席令第9号",
    "publishDate": "2018-08-31",
    "updateDate": "2018-08-31",
    "status": "现行有效",
    "summary": "个人所得税基本法律，2018年第七次修改引入综合所得制度，提高起征点至5000元/月，增加专项附加扣除。",
    "content": [
      {"section": "第一条", "text": "在中国境内有住所，或者无住所而一个纳税年度内在中国境内居住累计满183天的个人，为居民个人。居民个人从中国境内和境外取得的所得，依照本法规定缴纳个人所得税。在中国境内无住所又不居住，或者无住所而一个纳税年度内在中国境内居住累计不满183天的个人，为非居民个人。非居民个人从中国境内取得的所得，依照本法规定缴纳个人所得税。"},
      {"section": "第二条", "text": "下列各项个人所得，应当缴纳个人所得税：（一）工资、薪金所得；（二）劳务报酬所得；（三）稿酬所得；（四）特许权使用费所得；（五）经营所得；（六）利息、股息、红利所得；（七）财产租赁所得；（八）财产转让所得；（九）偶然所得。居民个人取得前款第一项至第四项所得（综合所得），按纳税年度合并计算个人所得税。"},
      {"section": "第三条", "text": "个人所得税税率：（一）综合所得，适用3%至45%的超额累进税率；（二）经营所得，适用5%至35%的超额累进税率；（三）利息、股息、红利所得，财产租赁所得，财产转让所得和偶然所得，适用比例税率，税率为20%。"},
      {"section": "第四条", "text": "免征个人所得税的项目。详见免征个人所得税的具体规定。"},
      {"section": "第六条", "text": "应纳税所得额的计算：（一）居民个人综合所得，以每一纳税年度收入额减除费用六万元以及专项扣除、专项附加扣除和依法确定的其他扣除后的余额。（二）非居民个人工资、薪金所得，以每月收入额减除费用五千元后的余额。（三）经营所得，以每一纳税年度收入总额减除成本、费用以及损失后的余额。（四）财产租赁所得，每次收入不超过四千元的，减除费用八百元；四千元以上的，减除20%的费用。（五）财产转让所得，以转让财产的收入额减除财产原值和合理费用后的余额。（六）利息、股息、红利所得和偶然所得，以每次收入额为应纳税所得额。劳务报酬所得、稿酬所得、特许权使用费所得以收入减除20%的费用后的余额为收入额。稿酬所得的收入额减按70%计算。"},
      {"section": "专项附加扣除", "text": "专项附加扣除包括：（一）子女教育：每个子女每月1000元（2023年起提高至2000元）；（二）继续教育：学历教育每月400元，职业资格定额3600元；（三）大病医疗：每年80000元限额内据实扣除；（四）住房贷款利息：每月1000元；（五）住房租金：每月800-1500元（根据城市不同）；（六）赡养老人：每月2000元（2023年起提高）；（七）婴幼儿照护：每个婴幼儿每月1000元（2023年起提高至2000元）。具体标准以最新政策为准。"}
    ]
  },
